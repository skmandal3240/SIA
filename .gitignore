# Build / generated artifacts
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# SIA dry-run artifacts
sia-lab/infra/outputs/
sia-lab/posttrain/outputs/

# Allow adapter metadata to be tracked, but not the big weights
!sia-lab/posttrain/adapter/
sia-lab/posttrain/adapter/**/*.safetensors
sia-lab/posttrain/adapter/**/*.bin
sia-lab/posttrain/adapter/**/tokenizer.json

# Models and data blobs
*.gguf
*.onnx
*.bin
*.safetensors
models/
.venv/
.worktrees/
sia-lab/eval/outputs/

# Device keystore (safety/crypto.py) -- never commit key material
.sia/
*.key
